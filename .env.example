# QSP-LLM-Workflows Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (required for batch processing)
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# Snippet Source Validation (Optional)
# =============================================================================
# These variables enable full-text verification of text snippets against
# their claimed sources. If not set, snippet source validation will be skipped.

# Email address for Unpaywall API (required for full-text fetching)
# Used to access open access papers
VALIDATION_EMAIL=your.email@jhu.edu

# Optional: Hopkins institutional proxy configuration
# Enables access to paywalled papers through your institution
# To get cookies: Login to Hopkins library, export browser cookies
HOPKINS_PROXY_URL=https://proxy1.library.jhu.edu/login?url=
HOPKINS_PROXY_COOKIES={"session": "your_session_cookie", "auth_token": "your_auth_token"}

# Optional: Cache directory for full-text (default: .cache/fulltext)
FULLTEXT_CACHE_DIR=.cache/fulltext
